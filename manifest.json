                    <a href="https://claude.ai" target="_blank" class="tool-card"><div class="tool-icon" style="background:#cc7b40"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="22" height="22"><circle cx="12" cy="12" r="9"/><path d="M8 12.5l2.5 2.5L16 9"/></svg></div><div class="tool-info"><div class="tool-name">Claude</div><div class="tool-cat">Anthropic · Analiz & Yazı</div></div><div class="tool-badge">№2</div></a>
                    <a href="https://gemini.google.com" target="_blank" class="tool-card"><div class="tool-icon" style="background:#4285f4"><svg viewBox="0 0 24 24" fill="currentColor" width="22" height="22"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-1 14H9V8h2v8zm4 0h-2V8h2v8z"/></svg></div><div class="tool-info"><div class="tool-name">Gemini</div><div class="tool-cat">Google · Çoxmodlu AI</div></div><div class="tool-badge">№3</div></a>
                    <a href="https://midjourney.com" target="_blank" class="tool-card"><div class="tool-icon" style="background:#1a1a2e"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="22" height="22"><polygon points="12 2 22 20 2 20"/></svg></div><div class="tool-info"><div class="tool-name">Midjourney</div><div class="tool-cat">AI · Şəkil yaradılması</div></div><div class="tool-badge">№4</div></a>
                    <a href="https://www.perplexity.ai" target="_blank" class="tool-card"><div class="tool-icon" style="background:#1e8bc3"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="22" height="22"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg></div><div class="tool-info"><div class="tool-name">Perplexity</div><div class="tool-cat">AI · Axtarış & Araşdırma</div></div><div class="tool-badge">№5</div></a>
                    <a href="https://www.cursor.com" target="_blank" class="tool-card"><div class="tool-icon" style="background:#7c3aed"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="22" height="22"><polyline points="16 18 22 12 16 6"/><polyline points="8 6 2 12 8 18"/></svg></div><div class="tool-info"><div class="tool-name">Cursor</div><div class="tool-cat">AI · Kod yaratma</div></div><div class="tool-badge">№6</div></a>
                    <a href="https://elevenlabs.io" target="_blank" class="tool-card"><div class="tool-icon" style="background:#f97316"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="22" height="22"><polygon points="11 5 6 9 2 9 2 15 6 15 11 19 11 5"/><path d="M19.07 4.93a10 10 0 0 1 0 14.14"/><path d="M15.54 8.46a5 5 0 0 1 0 7.07"/></svg></div><div class="tool-info"><div class="tool-name">ElevenLabs</div><div class="tool-cat">AI · Səs sintezi</div></div><div class="tool-badge">№7</div></a>
                    <a href="https://runwayml.com" target="_blank" class="tool-card"><div class="tool-icon" style="background:#059669"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="22" height="22"><polygon points="23 7 16 12 23 17 23 7"/><rect x="1" y="5" width="15" height="14" rx="2"/></svg></div><div class="tool-info"><div class="tool-name">Runway</div><div class="tool-cat">AI · Video yaradılması</div></div><div class="tool-badge">№8</div></a>
                    <a href="https://suno.com" target="_blank" class="tool-card"><div class="tool-icon" style="background:#8b5cf6"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="22" height="22"><path d="M9 18V5l12-2v13"/><circle cx="6" cy="18" r="3"/><circle cx="18" cy="16" r="3"/></svg></div><div class="tool-info"><div class="tool-name">Suno</div><div class="tool-cat">AI · Musiqi yaradılması</div></div><div class="tool-badge">№9</div></a>
                    <a href="https://www.notion.so/product/ai" target="_blank" class="tool-card"><div class="tool-icon" style="background:#1a1a1a"><svg viewBox="0 0 24 24" fill="currentColor" width="22" height="22"><path d="M4.459 4.208c.746.606 1.026.56 2.428.466l13.215-.793c.28 0 .047-.28-.046-.326L17.86 1.968c-.42-.326-.981-.7-2.055-.607L3.01 2.295c-.466.046-.56.28-.374.466zm.793 3.08v13.904c0 .747.373 1.027 1.214.98l14.523-.84c.841-.046.935-.56.935-1.167V6.354c0-.606-.233-.933-.748-.887l-15.177.887c-.56.047-.747.327-.747.933zm14.337.745c.093.42 0 .84-.42.888l-.7.14v10.264c-.608.327-1.168.514-1.635.514-.748 0-.935-.234-1.495-.933l-4.577-7.186v6.952L12.21 19s0 .84-1.168.84l-3.222.186c-.093-.186 0-.653.327-.746l.84-.233V9.854L7.822 9.76c-.094-.42.14-1.026.793-1.073l3.456-.233 4.764 7.279v-6.44l-1.215-.139c-.093-.514.28-.887.747-.933zM1.936 1.035l13.31-.98c1.634-.14 2.055-.047 3.082.7l4.249 2.986c.7.513.934.653.934 1.213v16.378c0 1.026-.373 1.634-1.68 1.726l-15.458.934c-.98.047-1.448-.093-1.962-.747l-3.129-4.06c-.56-.747-.793-1.306-.793-1.96V2.667c0-.839.374-1.54 1.447-1.632z"/></svg></div><div class="tool-info"><div class="tool-name">Notion AI</div><div class="tool-cat">AI · Produktivlik</div></div><div class="tool-badge">№10</div></a>
                </div>
            </div>
        </div>
    </div>

    <!-- SHARE TOAST -->
    <div class="share-toast" id="shareToast">🔗 Link kopyalandı!</div>

    <!-- NOTIFICATION PERMISSION BANNER -->
    <div class="notif-banner" id="notifBanner">
        <div class="notif-banner-content">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="20" height="20"><path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9"/><path d="M13.73 21a2 2 0 0 1-3.46 0"/></svg>
            <span>Yeni xəbərlərdən xəbərdar olmaq istərsinizmi?</span>
        </div>
        <div class="notif-banner-btns">
            <button class="notif-btn-allow" id="notifAllow">İcazə ver</button>
            <button class="notif-btn-deny" id="notifDeny">Sonra</button>
        </div>
    </div>

    <!-- HERO SECTION -->
    <section class="hero-section" id="heroSection"></section>

    <main class="container">
        <div class="main-layout">
            <section class="main-news">
                <h2 class="section-title">Yeniliklər</h2>
                <div class="news-list" id="newsList"></div>
                <div class="infinite-sentinel" id="infiniteSentinel"></div>
            </section>
            <aside class="sidebar">
                <h2 class="section-title">Çox oxunanlar</h2>
                <div class="sidebar-list"></div>
            </aside>
        </div>
    </main>

    <!-- NEWSLETTER -->
    <section class="newsletter-section">
        <div class="container">
            <div class="newsletter-inner">
                <div class="newsletter-text">
                    <h3>Yeniliklərə abunə ol</h3>
                    <p>Süni intellekt dünyasından ən son xəbərləri birbaşa e-poçtuna al.</p>
                </div>
                <div class="newsletter-form" id="newsletterForm">
                    <input type="email" id="newsletterEmail" placeholder="E-poçt ünvanınız..." autocomplete="email" />
                    <button id="newsletterSubmit">Abunə ol</button>
                </div>
                <div class="newsletter-success" id="newsletterSuccess" style="display:none">
                    ✅ Abunəliyiniz qeydə alındı!
                </div>
            </div>
        </div>
    </section>

    <footer class="site-footer">
        <div class="container">
            <div class="footer-logo">ainote<span>.az</span></div>
